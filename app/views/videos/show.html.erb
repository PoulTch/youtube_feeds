<div data-controller="video-player" data-video-player-video-id-value="<%= @video.id %>" style="font-family: sans-serif; max-width: 900px; margin: 0 auto;">
  
  <!-- Адаптивный контейнер для плеера (сохраняет пропорции 16:9) -->
  <div style="position: relative; padding-bottom: 56.25%; height: 0; overflow: hidden; border-radius: 16px; box-shadow: 0 10px 25px rgba(0,0,0,0.1); background: #000;">
    <iframe 
      src="https://www.youtube-nocookie.com/embed/<%= @video.youtube_video_id %>?autoplay=1&rel=0" 
      style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; border: none;" 
      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" 
      allowfullscreen>
    </iframe>
  </div>

  <!-- Информация о видео под плеером -->
  <h1 style="font-size: 1.6rem; color: #0f0f0f; margin-top: 24px; margin-bottom: 8px; line-height: 1.4;">
    <%= @video.title %>
  </h1>

  <div style="margin-bottom: 20px;">
    <a href="<%= channel_page_path(@video.channel) %>" style="text-decoration: none; color: #ff0000; font-weight: bold; font-size: 1.1rem;">
      🔴 <%= @video.channel.title %>
    </a>
    <span style="color: #606060; margin-left: 15px; font-size: 0.9rem;">
      Опубликовано: <%= @video.published_at.strftime("%d.%m.%Y в %H:%M") %>
    </span>
  </div>

  <!-- Описание видео -->
  <% if @video.description.present? %>
    <div style="background: #f2f2f2; padding: 20px; border-radius: 12px; font-size: 0.95rem; color: #0f0f0f; line-height: 1.6; white-space: pre-wrap;">
      <%= @video.description %>
    </div>
  <% end %>

</div>
