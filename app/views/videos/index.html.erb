<div style="font-family: sans-serif; max-width: 1200px; margin: 0 auto; padding: 20px;">

  <!-- ================= БЛОК: ПРОДОЛЖИТЬ ПРОСМОТР (ИСТОРИЯ) ================= -->
  <% if @history_videos.any? %>
    <div style="margin-bottom: 40px; background: #f9f9f9; padding: 24px; border-radius: 16px; box-shadow: inset 0 1px 4px rgba(0,0,0,0.03);">
      <h2 style="margin: 0 0 16px 0; font-size: 1.4rem; font-weight: bold; color: #0f0f0f; display: flex; align-items: center; gap: 8px;">
        ⏳ Продолжить просмотр
      </h2>
      
      <!-- Горизонтальная карусель для экономии места на экране -->
      <div style="display: flex; gap: 20px; overflow-x: auto; padding-bottom: 10px; scrollbar-width: thin;">
        <% @history_videos.each do |video| %>
          <div style="flex: 0 0 240px; background: #fff; border-radius: 12px; overflow: hidden; box-shadow: 0 4px 8px rgba(0,0,0,0.04); display: flex; flex-direction: column; justify-content: space-between;">
            
            <!-- ПРЕВЬЮ -->
            <a href="<%= watch_video_path(video) %>" title="<%= video.title %>" style="position: relative; display: block; overflow: hidden;">
              <% if video.thumbnail_url.present? %>
                <img src="<%= video.thumbnail_url %>" alt="" style="width: 100%; aspect-ratio: 16/9; object-fit: cover; display: block;">
              <% else %>
                <div style="width: 100%; aspect-ratio: 16/9; background: #e0e0e0; display: flex; align-items: center; justify-content: center; color: #888; font-size: 0.8rem;">Нет превью</div>
              <% end %>
              
              <!-- Плашка времени -->
              <% if video.duration_seconds.to_i > 0 %>
                <div style="position: absolute; bottom: 6px; right: 6px; background: rgba(0, 0, 0, 0.8); color: #fff; padding: 2px 4px; border-radius: 4px; font-size: 0.7rem; font-weight: bold; font-family: monospace;">
                  <%= Time.at(video.duration_seconds).utc.strftime(video.duration_seconds >= 3600 ? "%H:%M:%S" : "%M:%S") %>
                </div>
              <% end %>

              <!-- Красная полоса прогресса -->
              <% if video.duration_seconds.to_i > 0 %>
                <% progress = (video.watched_seconds.to_f / video.duration_seconds * 100).clamp(0, 100) %>
                <div style="position: absolute; bottom: 0; left: 0; width: 100%; height: 4px; background: rgba(255,255,255,0.3);">
                  <div style="width: <%= progress %>%; height: 100%; background: #ff0000;"></div>
                </div>
              <% end %>
            </a>

            <!-- ИНФОРМАЦИЯ -->
            <div style="padding: 10px 8px 8px 8px;">
              <h3 style="margin: 0 0 4px 0; font-size: 0.85rem; line-height: 1.3; font-weight: bold; max-height: 2.6rem; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;">
                <a href="<%= watch_video_path(video) %>" style="text-decoration: none; color: #0f0f0f;"><%= video.title %></a>
              </h3>
              <p style="margin: 0; font-size: 0.75rem; color: #ff0000; font-weight: bold; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                <%= video.channel.title %>
              </p>
            </div>

          </div>
        <% end %>
      </div>
    </div>
  <% end %>


  <!-- ================= БЛОК: ОБЩАЯ ЛЕНТА НОВИНОК ================= -->
  <h2 style="margin: 0 0 20px 0; font-size: 1.6rem; font-weight: bold; color: #0f0f0f;">✨ Общая лента контента</h2>

  <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 24px;">
    <% @videos.each do |video| %>
      <div style="display: flex; flex-direction: column; background: #fff; border-radius: 12px; overflow: hidden; box-shadow: 0 4px 6px rgba(0,0,0,0.05);">
        
        <a href="<%= watch_video_path(video) %>" title="<%= video.title %>" style="position: relative; display: block; overflow: hidden;">
          <% if video.thumbnail_url.present? %>
            <img src="<%= video.thumbnail_url %>" alt="<%= video.title %>" style="width: 100%; aspect-ratio: 16/9; object-fit: cover; display: block;">
          <% else %>
            <div style="width: 100%; aspect-ratio: 16/9; background: #e0e0e0; display: flex; align-items: center; justify-content: center; color: #888;">Нет превью</div>
          <% end %>
          
          <% if video.respond_to?(:duration_seconds) && video.duration_seconds.present? && video.duration_seconds > 0 %>
            <div style="position: absolute; bottom: 8px; right: 8px; background: rgba(0, 0, 0, 0.8); color: #fff; padding: 3px 6px; border-radius: 4px; font-size: 0.75rem; font-weight: bold; font-family: monospace; z-index: 5;">
              <%= Time.at(video.duration_seconds).utc.strftime(video.duration_seconds >= 3600 ? "%H:%M:%S" : "%M:%S") %>
            </div>
          <% end %>
        </a>

        <!-- Полоса прогресса на карточке общей ленты -->
        <div style="width: 100%; height: 4px; background: #e0e0e0; position: relative; margin-top: -4px; z-index: 10;">
          <div 
            data-static-progress="<%= video.youtube_video_id %>"
            style="width: <%= video.progress_percentage %>%; height: 100%; background: #ff0000; transition: width 0.3s;"
          ></div>
        </div>

        <div style="padding: 16px; flex-grow: 1; display: flex; flex-direction: column; justify-content: space-between;">
          <div>
            <h3 style="margin: 0 0 8px 0; font-size: 1rem; line-height: 1.4; color: #0f0f0f; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
              <a href="<%= watch_video_path(video) %>" title="<%= video.title %>" style="text-decoration: none; color: #0f0f0f; transition: color 0.2s;" onmouseover="this.style.color='#ff0000'" onmouseout="this.style.color='#0f0f0f'">
                <%= video.title %>
              </a>
            </h3>
            <p style="margin: 0 0 4px 0; font-size: 0.85rem; color: #606060; font-weight: bold;">
              <a href="<%= channel_page_path(video.channel) %>" style="text-decoration: none; color: #ff0000; font-weight: bold;">
                <%= video.channel.title %>
              </a>
            </p>
          </div>
          
          <div style="margin-top: 12px; font-size: 0.8rem; color: #909090;">
            <% if video.published_at.present? && video.published_at.respond_to?(:strftime) %>
              Опубликовано: <%= video.published_at.strftime("%d.%m.%Y в %H:%M") %>
            <% else %>
              Опубликовано: Скоро (Анонс)
            <% end %>
          </div>
        </div>

      </div>
    <% end %>
    
    <div class="youtube-pagination" style="margin-top: 40px; margin-bottom: 60px; display: flex; justify-content: center;">
      <%== @pagy.series_nav %>
    </div>

  </div> 
</div>
