<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "MyChannels" %></title>
    <!-- ВЕЧНЫЙ НЕУБИВАЕМЫЙ FAVICON ИЗ PUBLIC -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico?v=2">

    
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <!-- Подключаем иконки Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" rel="stylesheet">
  </head>

  <body style="margin: 0; padding: 0; background-color: #f9f9f9;">
    
    <!-- Главный контейнер, делящий экран на лево и право -->
    <div style="display: flex; font-family: sans-serif; min-height: 100vh;">
      
      <!-- ЛЕВАЯ ПАНЕЛЬ: САЙДБАР (фиксированный слева) -->
      <aside style="width: 260px; background: #f9f9f9; border-right: 1px solid #e5e5e5; padding: 20px; display: flex; flex-direction: column; justify-content: space-between; height: 100vh; position: fixed; box-sizing: border-box; overflow-y: auto;">
        
        <div>
          <!-- НАШ НОВЫЙ БРЕНДИНГ: MyChannels С ЧЕРНЫМ ЛОГОТИПОМ YOUTUBE -->
          <div style="font-size: 1.5rem; font-weight: bold; margin-bottom: 30px; display: flex; align-items: center; gap: 10px;">
            <i class="bi bi-youtube" style="color: #000000; font-size: 1.8rem;"></i>
            <span style="color: #ff0000;">MyChannels</span>
          </div>


          <!-- СТРОГАЯ ЧЕРНАЯ ИКОНКА ДЛЯ ОБЩЕЙ ЛЕНТЫ -->
          <a href="<%= root_path %>" style="display: flex; align-items: center; gap: 10px; text-decoration: none; color: #0f0f0f; font-weight: bold; font-size: 1.1rem; margin-bottom: 25px; transition: opacity 0.2s;" onmouseover="this.style.opacity='0.7'" onmouseout="this.style.opacity='1'">
            <i class="bi bi-house-door-fill" style="color: #000000; font-size: 1.3rem;"></i>
            Общая лента
          </a>


          <hr style="border: none; border-top: 1px solid #e5e5e5; margin-bottom: 20px;">

          <!-- УМНЫЙ СВЕРНУТЫЙ СПИСОК КАНАЛОВ -->
          <h3 style="font-size: 0.85rem; color: #606060; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 10px;">Мои Подписки (<%= @sidebar_channels.count %>)</h3>
          
          <details style="width: 100%;">
            <summary style="list-style: none; font-size: 0.9rem; color: #ff0000; font-weight: bold; cursor: pointer; padding: 8px 10px; background: #fff; border: 1px solid #e5e5e5; border-radius: 8px; text-align: center; margin-bottom: 15px; user-select: none; transition: background 0.2s;" onmouseover="this.style.background='#fff0f0'" onmouseout="this.style.background='#fff'">
              ▼ Развернуть список каналов
            </summary>
            
            <!-- Сам список каналов, который спрячется под кат -->
            <div style="max-height: 400px; overflow-y: auto; padding-right: 5px; display: flex; flex-direction: column; gap: 4px;">
              <% @sidebar_channels.each do |channel| %>
                <div style="display: flex; align-items: center; justify-content: space-between; padding: 6px 8px; border-radius: 6px; transition: background 0.2s;" onmouseover="this.style.background='#eee'" onmouseout="this.style.background='transparent'">
                  <a href="<%= channel_page_path(channel) %>" style="text-decoration: none; color: #0f0f0f; font-size: 0.9rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; flex-grow: 1; margin-right: 10px; display: flex; align-items: center; gap: 10px;">
                    <% if channel.avatar_url.present? %>
                      <!-- Если в базе есть ссылка на картинку (оригинальная или DiceBear) — выводим её! -->
                      <img src="<%= channel.avatar_url %>" alt="" style="width: 24px; height: 24px; border-radius: 50%; object-fit: cover; background: #e0e0e0; flex-shrink: 0;">
                    <% else %>
                      <!-- На всякий случай страховочный макет, если база еще не обновилась -->
                      <div style="width: 24px; height: 24px; border-radius: 50%; background: #0f0f0f; color: #fff; font-size: 0.7rem; display: flex; align-items: center; justify-content: center; font-weight: bold; flex-shrink: 0;">
                        <%= channel.title[0..1].upcase %>
                      </div>
                    <% end %>
                    <%= channel.title %>
                  </a>

                  <%= button_to "✕", delete_channel_path(channel), method: :delete, data: { turbo_confirm: "Удалить канал #{channel.title} и все его видео?" }, style: "background: none; border: none; color: #aaa; cursor: pointer; font-size: 0.8rem; padding: 2px 6px; border-radius: 4px;", onmouseover: "this.style.color='#ff0000'; this.style.background='#fff0f0'", onmouseout: "this.style.color='#aaa'; this.style.background='none'" %>
                </div>
              <% end %>
            </div>
          </details>
        </div>
        
        <!-- НИЖНЯЯ ЧАСТЬ: КНОПКА НАСТРОЕК + МОДАЛЬНОЕ ОКНО -->
  <div style="margin-top: auto; padding-top: 15px; border-top: 1px solid #e5e5e5;">
    <!-- Кнопка теперь открывает окно с помощью встроенного JS-метода showModal() -->
    <button onclick="document.getElementById('settings-dialog').showModal()" style="width: 100%; border: 1px solid #ccc; color: #0f0f0f; font-weight: bold; display: flex; align-items: center; justify-content: center; gap: 10px; padding: 12px; border-radius: 8px; background: #fff; box-shadow: 0 2px 5px rgba(0,0,0,0.05); cursor: pointer; transition: background 0.2s; font-size: 0.95rem;" onmouseover="this.style.background='#f2f2f2'" onmouseout="this.style.background='#fff'">
      ⚙️ Настройки системы
    </button>

    <!-- САМО ВСПЛЫВАЮЩЕЕ ОКНО (DIALOG) -->
    <dialog id="settings-dialog" style="border: none; border-radius: 16px; padding: 0; width: 550px; box-shadow: 0 20px 40px rgba(0,0,0,0.2); max-width: 90%; background: #ffffff;">
      
      <!-- Шапка окна с кнопкой закрытия -->
      <div style="background: #f9f9f9; padding: 16px 24px; border-bottom: 1px solid #e5e5e5; display: flex; align-items: center; justify-content: space-between;">
        <h2 style="margin: 0; font-size: 1.2rem; color: #0f0f0f;">⚙️ Настройки Feeds-Агрегатора</h2>
        <button onclick="document.getElementById('settings-dialog').close()" style="background: none; border: none; font-size: 1.5rem; color: #aaa; cursor: pointer; line-height: 1; padding: 0 5px;" onmouseover="this.style.color='#0f0f0f'" onmouseout="this.style.color='#aaa'">&times;</button>
      </div>

      <!-- Внутренности окна (Сюда мы спрятали наши формы управления) -->
      <div style="padding: 24px; display: flex; flex-direction: column; gap: 24px;">
        
        <!-- Форма 1: Добавление одного канала -->
        <%= form_with url: add_channel_path, method: :post, local: true, data: { turbo: false }, style: "display: flex; flex-direction: column; gap: 8px;" do |f| %>
          <label style="font-size: 0.9rem; font-weight: bold; color: #606060;">Добавить новый канал по ID:</label>
          <div style="display: flex; gap: 10px;">
            <%= f.text_field :youtube_channel_id, autocomplete: "off", placeholder: "Например: UC...", style: "padding: 10px 14px; border: 1px solid #ccc; border-radius: 8px; font-size: 0.95rem; flex-grow: 1; box-sizing: border-box;" %>
            <%= f.submit "Добавить", style: "background: #ff0000; color: #ffffff; border: none; padding: 10px 20px; border-radius: 8px; font-weight: bold; cursor: pointer; font-size: 0.95rem; transition: background 0.2s;", onmouseover: "this.style.background='#cc0000'", onmouseout: "this.style.background='#ff0000'" %>
          </div>
        <% end %>

        <hr style="border: none; border-top: 1px solid #e5e5e5; margin: 4px 0;">

        <!-- Форма 2: Массовый импорт подписок -->
        <div style="display: flex; flex-direction: column; gap: 8px;">
          <span style="font-size: 0.9rem; font-weight: bold; color: #606060;">Массовый импорт из YouTube (subscriptions.csv):</span>
          <%= form_with url: import_subscriptions_path, method: :post, local: true, multipart: true do |f| %>
            <label style="display: flex; align-items: center; justify-content: center; gap: 8px; background: #f2f2f2; color: #0f0f0f; padding: 12px 16px; border-radius: 8px; font-size: 0.95rem; font-weight: bold; cursor: pointer; border: 1px dashed #cccccc; text-align: center; transition: background 0.2s, border-color 0.2s;" onmouseover="this.style.background='#e6e6e6'; this.style.borderColor='#999999'" onmouseout="this.style.background='#f2f2f2'; this.style.borderColor='#cccccc'">
              📁 Выбрать файл подписок и загрузить
              <%= f.file_field :subscriptions_file, accept: ".csv", style: "display: none;", onchange: "this.form.submit();" %>
            </label>
          <% end %>
        </div>

      </div>
    </dialog>

    <!-- Стили для красивого размытия заднего фона модального окна -->
    <style>
      dialog::backdrop {
        background: rgba(0, 0, 0, 0.4);
        backdrop-filter: blur(4px);
      }
    </style>
  </div>


      </aside>


      <!-- ПРАВАЯ ПАНЕЛЬ: ОСНОВНОЙ КОНТЕНТ (Сюда подставляются вьюшки) -->
      <main style="flex-grow: 1; padding: 40px; box-sizing: border-box; overflow-x: hidden;">
        <%= yield %>
      </main>

    </div>

  </body>
</html>
