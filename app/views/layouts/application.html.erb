<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Youtube Feeds" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body style="margin: 0; padding: 0; background-color: #f9f9f9;">
    
    <!-- Главный контейнер, делящий экран на лево и право -->
    <div style="display: flex; font-family: sans-serif; min-height: 100vh;">
      
      <!-- ЛЕВАЯ ПАНЕЛЬ: САЙДБАР (фиксированный слева) -->
      <aside style="width: 260px; background: #ffffff; border-right: 1px solid #e5e5e5; padding: 20px; box-sizing: border-box; flex-shrink: 0; position: sticky; top: 0; height: 100vh; overflow-y: auto;">
        <div style="margin-bottom: 30px;">
          <a href="<%= root_path %>" style="text-decoration: none; color: #ff0000; font-size: 1.5rem; font-weight: bold; display: flex; align-items: center; gap: 8px;">
            📺 NewPipe Rails
          </a>
        </div>

        <h3 style="font-size: 0.85rem; color: #606060; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 15px;">Мои подписки</h3>
        
        <ul style="list-style: none; padding: 0; margin: 0;">
          <!-- Ссылка на общую ленту -->
          <li style="margin-bottom: 8px;">
            <a href="<%= root_path %>" style="display: block; padding: 10px 12px; border-radius: 8px; color: #0f0f0f; text-decoration: none; font-weight: bold; background: #f2f2f2;">
              🏠 Общая лента
            </a>
          </li>

          <!-- Список каналов из базы данных -->
          <% @sidebar_channels.each do |channel| %>
            <li style="margin-bottom: 4px; display: flex; align-items: center; justify-content: space-between; padding-right: 8px; border-radius: 8px; transition: background 0.2s;" onmouseover="this.style.background='#f2f2f2'" onmouseout="this.style.background='transparent'">
              
              <!-- Ссылка на сам канал (иконка + название) -->
              <a href="<%= channel_page_path(channel) %>" style="display: flex; align-items: center; gap: 10px; padding: 8px 12px; color: #0f0f0f; text-decoration: none; font-size: 0.95rem; overflow: hidden; flex-grow: 1;">
                <div style="width: 24px; height: 24px; background-color: #ff0000; color: #ffffff; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: bold; font-size: 0.75rem; flex-shrink: 0; text-transform: uppercase;">
                  <%= channel.title.to_s[0] %>
                </div>
                <span style="overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 140px;">
                  <%= channel.title %>
                </span>
              </a>

              <!-- Маленькая аккуратная кнопка удаления -->
              <%= button_to(delete_channel_path(channel), 
                            method: :delete, 
                            data: { confirm: "Вы точно хотите удалить канал #{channel.title} и все его ролики?" }, 
                            style: "background: none; border: none; color: #909090; cursor: pointer; font-size: 0.85rem; padding: 4px 8px; border-radius: 4px; display: flex; align-items: center; justify-content: center; transition: color 0.2s, background 0.2s;",
                            onmouseover: "this.style.color='#ff0000'; this.style.background='#ffe6e6'",
                            onmouseout: "this.style.color='#909090'; this.style.background='transparent'") do %>
                ✕
              <% end %>


            </li>

          <% end %>
        </ul>


      </aside>

      <!-- ПРАВАЯ ПАНЕЛЬ: ОСНОВНОЙ КОНТЕНТ (Сюда подставляются вьюшки) -->
      <main style="flex-grow: 1; padding: 40px; box-sizing: border-box; overflow-x: hidden;">
        <%= yield %>
      </main>

    </div>

  </body>
</html>
